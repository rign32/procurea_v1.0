{
  "name": "procurea-landing",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && node scripts/prerender.mjs",
    "build:en": "tsc -b && vite build --mode production-en && node scripts/prerender.mjs --mode=production-en",
    "build:staging": "tsc -b && vite build --mode staging && node scripts/prerender.mjs --mode=staging",
    "build:staging-en": "tsc -b && vite build --mode staging-en && node scripts/prerender.mjs --mode=staging-en",
    "preview": "vite preview",
    "generate:rfq-template": "node scripts/generate-rfq-template.mjs",
    "generate:tco-calculator": "node scripts/generate-tco-calculator.mjs",
    "generate:vendor-scoring": "node scripts/generate-vendor-scoring-framework.mjs",
    "generate:supplier-risk-checklist": "node scripts/generate-supplier-risk-checklist.mjs",
    "generate:nearshore-playbook": "node scripts/generate-nearshore-playbook.mjs",
    "sync-magnet": "node scripts/sync-magnet-from-figma.mjs",
    "sync-magnet:all": "node scripts/sync-magnet-from-figma.mjs --all",
    "sync-magnet:dry": "node scripts/sync-magnet-from-figma.mjs --dry-run"
  },
  "dependencies": {
    "@calcom/embed-react": "^1.5.3",
    "@tailwindcss/typography": "^0.5.19",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.563.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.0",
    "simple-icons": "^16.17.0",
    "tailwind-merge": "^3.0.0",
    "vanilla-cookieconsent": "^3.1.0"
  },
  "devDependencies": {
    "@react-pdf/renderer": "^4.5.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.17",
    "exceljs": "^4.4.0",
    "pdf-lib": "^1.17.1",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.6.0",
    "vite": "^6.0.0"
  }
}
