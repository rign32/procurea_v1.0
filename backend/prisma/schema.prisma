
generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x", "linux-musl", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- USER MANAGEMENT & SECURITY ---

// enum UserRole {
//   ADMIN
//   MANAGER
//   USER
//   VIEWER
// }

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String?   // Nullable for SSO users
  name          String?
  phone         String?   @unique
  role          String    @default("USER") // Legacy role field (backward compat)

  // RBAC Role
  rbacRoleId    String?
  rbacRole      Role?     @relation(fields: [rbacRoleId], references: [id])

  // Security
  ssoProvider   String?   // "google", "microsoft", "email"
  ssoId         String?   // Provider's unique ID
  pendingPhone  String?   // Temporarily store here during verification

  isEmailVerified Boolean @default(false)
  isPhoneVerified Boolean @default(false)
  phoneVerifiedAt DateTime?
  twoFactorEnabled Boolean @default(false)

  // Onboarding
  onboardingCompleted Boolean @default(false)
  companyName   String?
  jobTitle      String?
  language      String    @default("pl") // "pl", "en", "de"
  notificationPreferences String? // JSON string of preferences

  // Relations
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  
  // Auditing
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastLoginAt   DateTime?
  
  // Inverse Relations
  ownedRfqs     RfqRequest[] 
  auditLogs     AuditLog[]
  aiInteractions AiInteraction[]
  apiUsageLogs  ApiUsageLog[]
  
  // Permissions
  campaignAccess String  @default("own") // "all" | "own" | "readonly"
  plan          String  @default("research") // "research" | "pay_as_you_go" | "unlimited"

  // Billing & Credits
  searchCredits     Int     @default(10)
  stripeCustomerId  String? @unique
  stripeSubscriptionId          String?  @unique
  subscriptionCancelAtPeriodEnd Boolean  @default(false)
  creditTransactions CreditTransaction[]

  // Trial
  trialCreditsUsed  Boolean @default(false)
  trialEndedAcknowledgedAt DateTime?

  // Demo Mode
  isDemo        Boolean   @default(false)

  // Admin Controls
  isBlocked     Boolean   @default(false)
  blockedAt     DateTime?
  blockedReason String?

  // Refresh Tokens
  refreshTokens RefreshToken[]

  // Sharing Preferences (democratic team model)
  sharingFrom UserSharingPreference[] @relation("SharingFrom") // Preferences I set for others
  sharingTo   UserSharingPreference[] @relation("SharingTo")   // Preferences others set for me

  // In-app Feedback
  feedbacks   Feedback[]

  // Collaboration
  comments    Comment[]

  // Scheduled Reports
  scheduledReports ScheduledReport[]

  // Approvals
  approvalRequests  ApprovalRequest[] @relation("ApprovalRequester")
  approvalApprovals ApprovalRequest[] @relation("ApprovalApprover")

  // API Keys
  apiKeys     ApiKey[]

  // Documents
  documents   Document[]

  // Contracts
  contracts   Contract[]

  // Certificates reviewed (buyer approval gate for portal-uploaded certs)
  certificateReviews SupplierCertificate[] @relation("CertificateReviewer")

  // Workspaces
  workspaceMembers WorkspaceMember[]

  // Notifications
  notifications Notification[]

  // Purchase Orders created by this user (Sprint 4)
  createdPurchaseOrders PurchaseOrder[] @relation("PurchaseOrderCreatedBy")
}

// Refresh Token Model for secure session management
model RefreshToken {
  id          String   @id @default(uuid())
  userId      String
  token       String   @unique
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  revoked     Boolean  @default(false)
  revokedAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}

model Organization {
  id          String   @id @default(uuid())
  name        String
  domain      String?  // Auto-join users with this email domain

  // Customization (legacy)
  footerText  String?

  // Email Footer / Signature
  footerEnabled    Boolean  @default(false)
  footerFirstName  String?
  footerLastName   String?
  footerCompany    String?
  footerPosition   String?
  footerEmail      String?
  footerPhone      String?

  // Branding
  logoUrl           String?
  primaryColor      String?   // Hex color e.g. "#5E8C8F"
  accentColor       String?
  portalWelcomeText String?   // Custom welcome text for supplier portal

  // Currency Settings
  baseCurrency String @default("PLN") // ISO 4217 currency code

  // Shared Credit Pool
  searchCredits     Int     @default(10)
  trialCreditsUsed  Boolean @default(false)

  // Billing (org-level)
  plan                          String  @default("research") // "research" | "pay_as_you_go" | "unlimited"
  stripeCustomerId              String? @unique
  stripeSubscriptionId          String? @unique
  subscriptionCancelAtPeriodEnd Boolean @default(false)

  // Procurea Connect (ERP/CRM integrations add-on)
  hasConnectAddon      Boolean   @default(false)
  connectTrialStartedAt DateTime?
  connectTrialEndsAt    DateTime?

  users       User[]
  locations   OrganizationLocation[]
  orgCreditTransactions OrgCreditTransaction[]
  roles       Role[]
  workspaces  Workspace[]
  integrationConnections IntegrationConnection[]

  // Purchase Orders (Sprint 4)
  purchaseOrders PurchaseOrder[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// --- RBAC (Role-Based Access Control) ---

model Role {
  id          String   @id @default(uuid())
  name        String   // "owner" | "admin" | "manager" | "member" | "viewer" or custom
  displayName String
  permissions Json     // Array of permission strings (e.g. ["campaigns.create", "rfqs.send"])
  isSystem    Boolean  @default(false) // System roles can't be deleted

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  users       User[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([name, organizationId])
  @@index([organizationId])
}

model OrganizationLocation {
  id             String   @id @default(uuid())
  name           String   // e.g. "HQ", "Warehouse A"
  address        String   // Full address
  isDefault      Boolean  @default(false)
  
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  
  // Relations
  rfqRequests    RfqRequest[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model VerificationToken {
  identifier String   // Email or Phone
  token      String
  expires    DateTime
  type       String   // EMAIL_CODE, PHONE_CODE, RESET_PASSWORD
  
  createdAt  DateTime @default(now())

  @@unique([identifier, token])
}

// --- CORE DOMAIN MODELS ---

model Campaign {
  id        String   @id @default(uuid())
  name      String   @default("My Strategy Campaign")
  language  String   @default("pl")
  status    String   @default("RUNNING")
  stage     String   @default("STRATEGY")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Soft Delete
  deletedAt DateTime?

  // Email Sequence
  sequenceTemplateId String?
  sequenceTemplate   SequenceTemplate? @relation(fields: [sequenceTemplateId], references: [id])

  // Search criteria (persisted for campaign re-run and audit trail)
  searchCriteria Json?

  // Industry-aware brief (v2 wizard)
  // industry: manufacturing | events | construction | horeca | healthcare | retail | logistics | mro | other
  industry      String?
  // sourcingMode: product | service | mixed
  sourcingMode  String?
  // Raw user-written brief (free-text from new wizard step 1)
  brief         String?
  // Structured fields extracted from brief by Gemini parser
  parsedBrief   Json?

  // AI Campaign Summary
  aiSummary            String?
  aiSummaryGeneratedAt DateTime?

  // Apollo Enrichment
  apolloEnrichmentStatus String?

  // Feedback Survey
  feedbackEmailSentAt  DateTime?

  logs      Log[]
  suppliers Supplier[]
  rfqRequest RfqRequest?
  metrics   CampaignMetrics?
}

model CampaignMetrics {
  id                  String   @id @default(uuid())
  campaignId          String   @unique
  campaign            Campaign @relation(fields: [campaignId], references: [id])

  // Funnel
  urlsCollected       Int      @default(0)
  urlsProcessed       Int      @default(0)
  screenerPassed      Int      @default(0)
  screenerFallback    Int      @default(0)
  auditorApproved     Int      @default(0)
  auditorRejected     Int      @default(0)
  auditorNeedsReview  Int      @default(0)

  // Quality
  avgCapabilityScore  Float?
  avgTrustScore       Float?

  // Cost
  geminiCalls         Int      @default(0)
  serperCalls         Int      @default(0)
  totalCost           Float    @default(0)
  costPerSupplier     Float?

  // Rejection breakdown
  rejectionReasons    Json?

  // Sprint 3: hard filter counters — track how many suppliers got dropped after Auditor
  // by deterministic rules (required cert, MOQ, lead time, geography, voivodeship).
  // Surfaced in campaign UI as "Found X / passed filters Y / rejected Z (47 missing CE…)".
  hardFilteredCerts        Int @default(0)
  hardFilteredMoq          Int @default(0)
  hardFilteredLeadTime     Int @default(0)
  hardFilteredGeography    Int @default(0)
  hardFilteredVoivodeship  Int @default(0)

  // Timing
  totalDurationMs     Int?

  // Flags
  lowYieldModeUsed    Boolean  @default(false)
  expansionUsed       Boolean  @default(false)
  similarityUsed      Boolean  @default(false)

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Supplier {
  id             String   @id @default(uuid())
  campaignId     String
  url            String
  
  // Frontend Mapped Fields
  name           String?
  country        String?
  city           String?
  website        String?
  
  // Raw Agent Results (JSON strings)
  explorerResult String?
  analystResult  String?
  enrichmentResult String?
  auditorResult  String?
  
  analysisScore  Float?
  analysisReason String?

  // Rich Data Fields
  specialization String?
  certificates   String? // Stored as comma-separated string or JSON
  employeeCount  String?
  contactEmails  String? // Comma-separated list of contact emails
  
  // AI & RAG
  documentChunks DocumentChunk[]
  metadata       String? // JSON for flexible metadata

  campaign       Campaign @relation(fields: [campaignId], references: [id])
  
  offers         Offer[]

  // Origin Tracking
  originLanguage String?  @default("en") // Language of the strategy that found this
  originCountry  String?  @default("Global") // Country/Region of the strategy
  sourceAgent    String?  @default("SourcingPipeline") // Agent or Worker ID
  
  // Link to Global Registry
  registryId     String?
  registry       CompanyRegistry? @relation(fields: [registryId], references: [id])
  
  // Structured Contacts
  contacts       Contact[]

  // Company Classification
  companyType               String?   @default("NIEJASNY")  // PRODUCENT, HANDLOWIEC, NIEJASNY
  companyTypeConfidence      Int?      @default(0)
  needsManualClassification  Boolean   @default(false)
  sourceType                String?   @default("SEARCH")    // SEARCH, PORTAL_MINE, LEADER_DIRECT, LEADER_SEARCH, EXPANSION

  // Internal notes & tags (private per organization)
  internalNotes  String?
  internalTags   Json?     // Array of string tags like ["preferred", "quality-issues", "local"]

  // Procurea Connect: matches against customer's ERP
  externalMatches SupplierMatch[]

  // Supplier quality score 0-100 (Sprint 3) — computed from response rate, offer completeness, CompanyRegistry signals
  qualityScore   Float?

  // Structured certificates (Sprint #2 — replaces legacy `certificates` string incrementally)
  structuredCertificates SupplierCertificate[]

  // Soft Delete
  deletedAt DateTime?

  @@index([qualityScore])
}

// Structured supplier certificate with expiry tracking + optional document link (Sprint #2)
model SupplierCertificate {
  id          String   @id @default(uuid())

  supplierId  String
  supplier    Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  // Certificate identity
  type        String   // Enum: see certificate-types.ts
  code        String
  issuer      String?
  certNumber  String?

  // Dates
  issuedAt    DateTime?
  validUntil  DateTime? // Optional — PIPELINE-discovered certs often lack a date; drives expiry alerts when present

  // Document link (uploaded PDF/image) — optional
  documentId  String?
  document    Document? @relation(fields: [documentId], references: [id], onDelete: SetNull)

  // URL where cert was discovered (PIPELINE only) — lets buyers verify the source
  sourceUrl   String?

  // Evidence tier — EXTRACTED (string match only) | EVIDENCED (number/date/issuer/url found) | VERIFIED (cross-checked with external registry)
  verificationStatus String @default("EXTRACTED")

  // Computed/cached status — ACTIVE | EXPIRING_SOON | EXPIRED | UNKNOWN
  status      String   @default("ACTIVE")

  // Provenance: MANUAL (buyer typed in) | PORTAL (supplier uploaded via access token) | PIPELINE (AI-discovered during sourcing)
  source      String   @default("MANUAL")

  // Buyer review gate for PORTAL-uploaded certs
  // PENDING | APPROVED | REJECTED — MANUAL certs default APPROVED on create
  reviewStatus String   @default("APPROVED")
  reviewedAt   DateTime?
  reviewedById String?
  reviewedBy   User?    @relation("CertificateReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewNotes  String?

  // Alerting state — prevents duplicate email alerts
  lastAlertedAt DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([supplierId, type, code])
  @@index([supplierId])
  @@index([validUntil])
  @@index([status])
  @@index([source])
  @@index([reviewStatus])
  @@index([verificationStatus])
}

model Contact {
  id              String   @id @default(uuid())
  supplierId      String
  supplier        Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  name            String?
  role            String?
  email           String?
  phone           String?
  isDecisionMaker Boolean  @default(false)

  apolloId        String?
  linkedinUrl     String?
  department      String?
  seniority       String?
  emailStatus     String?
  enrichedAt      DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([email])
  @@index([supplierId])
}

model Log {
  id         String   @id @default(uuid())
  campaignId String
  message    String
  severity   String   @default("info") // info, warning, error, critical
  timestamp  DateTime @default(now())

  campaign   Campaign @relation(fields: [campaignId], references: [id])

  @@index([campaignId, severity])
}

// --- AI & KNOWLEDGE BASE ---

model DocumentChunk {
  id          String   @id @default(uuid())
  content     String   // The actual text chunk
  
  // Vector embedding (stored as JSON array, can use pgvector extension later)
  vector      String?
  
  sourceUrl   String?
  
  supplierId  String?
  supplier    Supplier? @relation(fields: [supplierId], references: [id])
  
  createdAt   DateTime @default(now())
}

model AiInteraction {
  id          String   @id @default(uuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  
  campaignId  String?
  
  prompt      String
  response    String
  modelUsed   String
  tokensUsed  Int?
  feedback    Int?     // User rating 1-5
  
  createdAt   DateTime @default(now())
}

// --- API USAGE TRACKING ---

model ApiUsageLog {
  id             String   @id @default(uuid())
  
  // Tracking
  service        String   // "gemini" | "serper"
  endpoint       String?  // Specific endpoint/model used
  
  userId         String?
  user           User?    @relation(fields: [userId], references: [id])

  campaignId     String?  // Link API calls to campaigns for cost attribution

  // Request details
  requestPayload String?  // Truncated query (first 500 chars)
  
  // Results
  status         String   // "success" | "error"
  errorMessage   String?
  
  // Cost tracking
  tokensUsed     Int?      // For Gemini
  estimatedCost  Float?    // Estimated cost in USD
  responseTimeMs Int?      // Response time in milliseconds
  
  createdAt      DateTime @default(now())
  
  @@index([service, createdAt])
  @@index([userId])
  @@index([status])
  @@index([campaignId])
}

// --- SMART CACHE MODELS ---

// Caches SerpApi search results with 30-day TTL
model SearchQueryCache {
  id         String   @id @default(uuid())
  queryHash  String   @unique // SHA256 hash of normalized query
  queryText  String   // Original query for debugging
  results    String   // JSON array of {title, link, snippet}
  createdAt  DateTime @default(now())
  expiresAt  DateTime // createdAt + 30 days

  @@index([queryHash])
}

// Global registry of processed companies (indexed by domain)
// This is the COLLECTIVE KNOWLEDGE BASE - aggregates data from ALL campaigns/users
model CompanyRegistry {
  id              String   @id @default(uuid())
  domain          String   @unique // Root domain (e.g., example.com)
  name            String?
  country         String?
  city            String?
  specialization  String?
  certificates    String?  // Comma-separated
  employeeCount   String?
  
  // CRITICAL: Contact Information
  contactEmails   String?  // Comma-separated list of discovered emails
  primaryEmail    String?  // Best email for contact (first discovered, or most responsive)
  
  // Raw agent results (JSON strings)
  explorerResult    String?
  analystResult     String?
  enrichmentResult  String?
  auditorResult     String?

  // Quality Metrics
  lastAnalysisScore Float?
  dataQualityScore  Float?  // 0-100 based on completeness
  
  // Usage Statistics - COLLECTIVE LEARNING
  usageCount        Int      @default(0)  // How many times this supplier was found/used
  campaignsCount    Int      @default(0)  // In how many campaigns appeared
  rfqsSent          Int      @default(0)  // How many RFQs sent to this supplier
  rfqsResponded     Int      @default(0)  // How many RFQs they responded to
  
  // Engagement Tracking
  lastContactedAt   DateTime?  // When last RFQ was sent
  lastResponseAt    DateTime?  // When last response received
  responseRate      Float?     // rfqsResponded / rfqsSent
  avgResponseTime   Float?     // Average hours to respond
  
  // Supplier Status
  isActive          Boolean  @default(true)   // Still in business
  isVerified        Boolean  @default(false)  // Manually verified by user
  isBlacklisted     Boolean  @default(false)  // Marked as unreliable
  blacklistReason   String?
  
  // AI Vector ID (reference to external or internal vector store)
  vectorId          String?
  
  // Timestamps
  createdAt         DateTime @default(now())
  lastProcessedAt   DateTime @default(now())
  lastUpdatedAt     DateTime @updatedAt
  
  // Search Keywords
  keywords          String?  // JSON array of associated keywords

  suppliers         Supplier[] // Back-relation to Campaign Suppliers

  @@index([domain])
  @@index([name])
  @@index([country])
  @@index([isActive, usageCount])
}

// --- BUSINESS LOGIC MODELS (CRM & RFQ) ---

// 1. RFQ Request - The "Ask"
// Represents what we are buying (Product Specs, Targets)
// Separated from Campaign (Shadow Sourcing)
model RfqRequest {
  id          String   @id @default(uuid())
  status      String   @default("DRAFT") // DRAFT, ACTIVE, CLOSED, ARCHIVED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Soft Delete
  deletedAt   DateTime?
  
  // Public ID (Human readable)
  publicId    String?  // e.g. "RFQ-2026-001"
  
  // Product Specification
  productName String
  partNumber  String?
  category    String?
  material    String?
  description String?
  
  // Commercial Targets
  targetPrice Float?
  currency    String   @default("EUR")
  quantity    Int
  eau         Int?     // Estimated Annual Usage
  unit        String   @default("pcs")
  
  // Logistics
  incoterms       String?
  paymentTerms    String?
  deliveryAddress String? // Legacy/Manual address override
  
  deliveryLocationId String?
  deliveryLocation   OrganizationLocation? @relation(fields: [deliveryLocationId], references: [id])

  desiredDeliveryDate DateTime?    // Target Delivery Date
  offerDeadline       DateTime?    // Deadline for submitting offers
  
  // Attachments (S3/Local paths)
  attachments     String? // JSON array

  // Weighted Ranking Configuration (per RFQ override; falls back to defaults)
  // JSON: { price: 0.25, leadTime: 0.20, moq: 0.15, quality: 0.25, compliance: 0.15 }
  rankingWeights  Json?

  // Relations
  campaign    Campaign? @relation(fields: [campaignId], references: [id])
  campaignId  String?   @unique // Link to Sourcing Campaign (optional)

  offers      Offer[] // Received offers

  // Multi-SKU / BOQ line items (Sprint #4) — RFQ can quote a list of positions
  // instead of one productName. Legacy single-item RFQs stay as-is (no line items).
  lineItems   RfqLineItem[]

  ownerId     String? // Internal User ID
  owner       User?   @relation(fields: [ownerId], references: [id])
}

// Individual line item within a multi-SKU RFQ / BOQ tender (Sprint #4)
model RfqLineItem {
  id          String   @id @default(uuid())

  rfqRequest  RfqRequest @relation(fields: [rfqRequestId], references: [id], onDelete: Cascade)
  rfqRequestId String

  // Position in list (user-sortable)
  sortOrder   Int      @default(0)

  // SKU / code (from BOQ line number or internal part number)
  sku         String?

  // Description visible to supplier
  name        String

  // Detailed spec (material, size, grade…)
  description String?
  material    String?

  // Commercial
  quantity    Float
  unit        String   @default("pcs")
  targetPrice Float?  // Optional per-item target

  // Certifications/compliance flags expected on this line
  requiredCerts Json?  // Array of certificate type codes (e.g. ["CE", "ISO_9001"])

  // Reverse relation — per-line quotes from suppliers (Faza 2B)
  offerLineItems OfferLineItem[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([rfqRequestId])
  @@index([rfqRequestId, sortOrder])
}

// Per-line-item quote from a supplier (Faza 2B — completes multi-SKU loop).
// Allows bidders to price each RFQ position separately so the buyer can
// compare line-by-line, award per-line, or split across suppliers.
model OfferLineItem {
  id              String   @id @default(uuid())

  offerId         String
  offer           Offer    @relation(fields: [offerId], references: [id], onDelete: Cascade)

  rfqLineItemId   String
  rfqLineItem     RfqLineItem @relation(fields: [rfqLineItemId], references: [id], onDelete: Cascade)

  // Supplier's quote for this line
  unitPrice       Float?
  currency        String?  @default("EUR")
  moq             Int?
  leadTime        Int?     // weeks

  // Supplier can flag alternatives/substitutes at line level
  altDescription  String?
  altMaterial     String?

  notes           String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([offerId, rfqLineItemId])
  @@index([offerId])
  @@index([rfqLineItemId])
}

// 2. Offer - The "Bid" (Response from Supplier)
model Offer {
  id          String   @id @default(uuid())
  status      String   @default("PENDING") // PENDING (Invited), VIEWED, SUBMITTED, REJECTED, SHORTLISTED, ACCEPTED
  
  // Commercials (Filled by Supplier)
  price       Float?
  currency    String?  @default("EUR")
  moq         Int?
  leadTime    Int?     // In weeks
  validityDate DateTime?
  
  // Checkboxes / Compliance
  incotermsConfirmed Boolean @default(false)
  specsConfirmed     Boolean @default(false)
  
  comments    String?

  // Relations
  rfqRequest   RfqRequest @relation(fields: [rfqRequestId], references: [id])
  rfqRequestId String

  supplier     Supplier   @relation(fields: [supplierId], references: [id])
  supplierId   String

  // SUPPLIER PORTAL ACCESS
  // This token allows the supplier to access the specific offer page without login
  accessToken  String     @unique @default(uuid())
  tokenExpiresAt DateTime?

  // Resend outbound email_id — used to match incoming replies via In-Reply-To header (Sprint 1)
  resendEmailId String?   @unique

  // Audit
  viewedAt     DateTime?
  submittedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Sequence Executions
  sequenceExecutions SequenceExecution[]

  // Price Tiers (quantity-based pricing)
  priceTiers    OfferPriceTier[]

  // Alternative Offer (self-reference)
  parentOfferId String?
  parentOffer   Offer?  @relation("OfferAlternatives", fields: [parentOfferId], references: [id])
  alternatives  Offer[] @relation("OfferAlternatives")

  // Alternative offer description
  altDescription String?
  altMaterial    String?

  // Language used by supplier in portal
  submissionLanguage String?

  // Supplier-uploaded attachments (JSON array of { filename, originalName, url })
  attachments Json?

  // Counter-offer / Negotiation
  counterOfferTerms Json?    // Buyer's counter: { price?, moq?, leadTime?, comments? }
  negotiationHistory Json?   // Array of { action, by, terms, timestamp }

  // Contracts
  contracts   Contract[]

  // Inbound email replies (Sprint 1) + Purchase Orders (Sprint 4)
  replies         OfferReply[]
  purchaseOrders  PurchaseOrder[]

  // Per-line quotes for multi-SKU / BOQ RFQs (Faza 2B)
  lineItems       OfferLineItem[]

  // Weighted Ranking (computed when offers are compared)
  // Final score 0-100 (weighted sum of per-criterion scores)
  weightedRankingScore     Float?
  // Per-criterion breakdown: { priceScore, leadTimeScore, moqScore, qualityScore, complianceScore, finalScore }
  weightedRankingBreakdown Json?

  @@index([weightedRankingScore])
}

// Price tier for quantity-based pricing
model OfferPriceTier {
  id        String   @id @default(uuid())
  offerId   String
  offer     Offer    @relation(fields: [offerId], references: [id], onDelete: Cascade)
  minQty    Int
  maxQty    Int?     // null = last tier ("and above")
  unitPrice Float
  createdAt DateTime @default(now())

  @@index([offerId])
}

// --- SYSTEM HEALTH & AUDIT ---

model AuditLog {
  id          String   @id @default(uuid())

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  action      String   // CREATE, UPDATE, DELETE
  entityType  String   // Supplier, Campaign, User
  entityId    String
  changes     String?  // JSON diff { "old": ..., "new": ... }
  metadata    String?  // JSON IP, user-agent etc
  
  createdAt   DateTime @default(now())
  
  @@index([entityType, entityId])
  @@index([userId])
}


model SequenceTemplate {
  id        String   @id @default(uuid())
  name      String
  isSystem  Boolean  @default(false)
  // Industry + sourcing mode targeting — Sprint 2 C1. Used by SourcingService to
  // auto-pick a default template matching the campaign's branch when user didn't
  // explicitly choose one. Both nullable = generic template.
  industry     String?
  sourcingMode String?
  steps     SequenceStep[]
  campaigns Campaign[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([industry, sourcingMode])
}

model SequenceStep {
  id          String   @id @default(uuid())
  dayOffset   Int
  type        String   // INITIAL, REMINDER, FINAL
  subject     String
  bodySnippet String

  template    SequenceTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  templateId  String

  executions  SequenceExecution[]
}

model SequenceExecution {
  id             String   @id @default(uuid())
  offerId        String
  stepId         String
  recipientEmail String?  // Track which contact received this email
  sentAt         DateTime? // Nullable, as we create PENDING records first
  status         String   @default("SENT") // PENDING, SENT, FAILED, SKIPPED
  createdAt      DateTime @default(now())

  offer    Offer        @relation(fields: [offerId], references: [id], onDelete: Cascade)
  step     SequenceStep @relation(fields: [stepId], references: [id], onDelete: Cascade)

  @@unique([offerId, stepId, recipientEmail])
  @@index([offerId])
}

// --- CURRENCY EXCHANGE RATES ---

model CurrencyExchangeRate {
  id            String   @id @default(uuid())

  // Currency code (ISO 4217)
  currencyCode  String   // e.g., "USD", "EUR", "GBP"
  currencyName  String   // e.g., "dolar amerykański"

  // Exchange rate to PLN (NBP provides rates vs PLN)
  rateToPln     Float    // e.g., 4.0234 (1 USD = 4.0234 PLN)

  // Date this rate is valid for
  effectiveDate DateTime

  // NBP table metadata
  tableNumber   String?  // e.g., "045/A/NBP/2026"

  // Timestamps
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([currencyCode, effectiveDate])
  @@index([effectiveDate])
  @@index([currencyCode])
}

// --- BILLING & CREDITS ---

model CreditTransaction {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount           Int      // +N for purchase, -1 for consumption
  type             String   // "PURCHASE" | "CONSUMPTION" | "SUBSCRIPTION_GRANT" | "CONTRIBUTION"
  description      String?
  stripeSessionId  String?
  campaignId       String?
  balanceAfter     Int
  createdAt        DateTime @default(now())

  @@index([userId, createdAt])
  @@index([stripeSessionId])
}

// Organization-level credit transactions (shared pool)
model OrgCreditTransaction {
  id               String       @id @default(uuid())
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId           String?      // Which user triggered this transaction
  amount           Int          // +N for purchase/grant, -1 for consumption
  type             String       // "TRIAL_GRANT" | "MEMBER_BONUS" | "CONSUMPTION" | "CONTRIBUTION" | "SUBSCRIPTION_GRANT"
  description      String?
  stripeSessionId  String?
  campaignId       String?
  balanceAfter     Int
  createdAt        DateTime     @default(now())

  @@index([organizationId, createdAt])
  @@index([stripeSessionId])
}

// Per-pair sharing preference (democratic team model)
model UserSharingPreference {
  id          String  @id @default(uuid())
  fromUserId  String  // The user who owns the data
  toUserId    String  // The user who can see the data
  enabled     Boolean @default(false)

  fromUser    User @relation("SharingFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser      User @relation("SharingTo", fields: [toUserId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([fromUserId, toUserId])
  @@index([fromUserId])
  @@index([toUserId])
}

// --- OBSERVABILITY ---

model ObservabilityEvent {
  id          String   @id @default(uuid())
  category    String   // auth | conversion | campaign | error
  type        String   // registration_blocked | trial_exhausted | plan_viewed | low_supplier_count | pipeline_error...
  severity    String   @default("info") // info | warning | error | critical
  userId      String?
  userEmail   String?
  campaignId  String?
  title       String
  message     String?
  metadata    Json?
  slackSent   Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([category, createdAt])
  @@index([userId])
  @@index([severity, createdAt])
  @@index([type, createdAt])
}

// --- STRIPE EVENT LOG (webhook deduplication) ---

model StripeEventLog {
  id          String   @id // Stripe event ID (evt_xxx)
  type        String   // checkout.session.completed, customer.subscription.updated, etc.
  processedAt DateTime @default(now())

  @@index([type, processedAt])
}

// --- MONITORING INCIDENTS ---

// --- IN-APP FEEDBACK ---

model Feedback {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // "bug" | "feature" | "other"
  message   String
  page      String?  // current page URL
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([type, createdAt])
}

// --- COLLABORATION ---

model Comment {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  entityType String   // "campaign" | "supplier" | "rfq"
  entityId   String

  content    String
  mentions   Json?    // Array of mentioned user IDs

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([entityType, entityId])
  @@index([userId])
}

// --- SCHEDULED REPORTS ---

model ScheduledReport {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String
  frequency   String    // "daily" | "weekly" | "monthly"
  reportType  String    // "campaign_summary" | "analytics" | "supplier_performance"
  recipients  Json      // Array of email addresses
  filters     Json?     // Optional filters
  enabled     Boolean   @default(true)
  lastRunAt   DateTime?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
  @@index([enabled, frequency])
}

// --- PUBLIC API KEYS ---

model ApiKey {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String    // User-friendly name
  hashedKey   String    @unique // SHA256 hash of the raw API key
  prefix      String    // First 10 chars for display (pk_xxxxx...)
  scopes      Json      // Array of allowed scopes: ["read", "write", "campaigns", "suppliers"]
  enabled     Boolean   @default(true)
  expiresAt   DateTime?
  lastUsedAt  DateTime?

  createdAt   DateTime  @default(now())

  @@index([userId])
}

// --- APPROVAL WORKFLOWS ---

model ApprovalRequest {
  id          String    @id @default(uuid())

  requesterId String
  requester   User      @relation("ApprovalRequester", fields: [requesterId], references: [id])

  approverId  String
  approver    User      @relation("ApprovalApprover", fields: [approverId], references: [id])

  entityType  String    // "rfq" | "offer_accept" | "campaign_delete"
  entityId    String

  status      String    @default("PENDING") // PENDING | APPROVED | REJECTED
  reason      String?   // Why approval was requested
  comments    String?   // Approver's comments

  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([approverId, status])
  @@index([requesterId])
  @@index([entityType, entityId])
}

// --- DOCUMENT MANAGEMENT ---

model Document {
  id             String    @id @default(uuid())

  // Ownership
  uploadedById   String
  uploadedBy     User      @relation(fields: [uploadedById], references: [id], onDelete: Cascade)
  organizationId String?

  // File info
  filename       String    // Stored filename (UUID-based)
  originalName   String    // Original filename
  mimeType       String
  sizeBytes      Int
  url            String    // Download URL path

  // Organization
  category       String?   // "certificate" | "drawing" | "nda" | "spec" | "quality_report" | "contract" | "other"
  tags           Json?     // Array of string tags
  description    String?

  // Entity linking (polymorphic)
  entityType     String?   // "supplier" | "rfq" | "offer" | "campaign"
  entityId       String?

  // Versioning
  version        Int       @default(1)
  parentId       String?   // Previous version
  parent         Document? @relation("DocumentVersions", fields: [parentId], references: [id])
  versions       Document[] @relation("DocumentVersions")
  isLatest       Boolean   @default(true)

  // Back-ref from structured supplier certificates (Sprint #2)
  supplierCertificates SupplierCertificate[]

  createdAt      DateTime  @default(now())

  @@index([uploadedById])
  @@index([organizationId])
  @@index([entityType, entityId])
  @@index([category])
}

// --- CONTRACT MANAGEMENT ---

model Contract {
  id              String    @id @default(uuid())

  offerId         String
  offer           Offer     @relation(fields: [offerId], references: [id])

  createdById     String
  createdBy       User      @relation(fields: [createdById], references: [id])

  organizationId  String?

  title           String
  terms           String?   // Contract terms text
  status          String    @default("DRAFT") // DRAFT | UNDER_REVIEW | SIGNED | ACTIVE | EXPIRED | TERMINATED

  startDate       DateTime?
  endDate         DateTime?
  signedAt        DateTime?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Purchase Orders generated from this contract (Sprint 4)
  purchaseOrders  PurchaseOrder[]

  @@index([createdById])
  @@index([organizationId])
  @@index([status])
}

model MonitoringIncident {
  id          String    @id @default(uuid())
  serviceId   String    // "gemini", "serper", "database", "resend", "app_pl", "app_io"
  status      String    @default("open") // open | resolved
  startedAt   DateTime  @default(now())
  resolvedAt  DateTime?
  durationMs  Int?
  lastAlertAt DateTime  @default(now())
  severity    String    @default("warning") // warning | critical
  title       String
  message     String?
  metadata    Json?

  @@index([serviceId, status])
  @@index([status, startedAt])
}

// --- WORKSPACES (Team Project Isolation) ---

model Workspace {
  id              String   @id @default(uuid())
  name            String
  description     String?
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])

  members         WorkspaceMember[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([organizationId])
}

// --- IN-APP NOTIFICATIONS ---

model Notification {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  type       String   // "approval_request" | "offer_submitted" | "campaign_completed" | "comment_mention"
  title      String
  message    String?
  entityType String?  // "campaign" | "supplier" | "rfq" | "approval"
  entityId   String?

  read       Boolean  @default(false)

  createdAt  DateTime @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
}

model WorkspaceMember {
  id          String    @id @default(uuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        String    @default("member") // "admin" | "member" | "viewer"

  createdAt   DateTime  @default(now())

  @@unique([workspaceId, userId])
  @@index([userId])
}

// --- INBOUND LEADS (landing page contact forms) ---
//
// Captures pre-registration inquiries from procurea.pl/.io contact pages.
// Not tied to User (lead may never register). Used by sales for qualification.
model Lead {
  id        String   @id @default(uuid())
  name      String
  company   String?
  email     String
  phone     String?
  // Intent signal — maps to pricing/integration interest dropdown on the form
  interest  String   // e.g. "sourcing_starter" | "full_bundle" | "enterprise_custom" | "integration_sap" | "other"
  message   String?
  // Where the form was submitted from (e.g. "contact_page", "pricing_page_enterprise", "integrations_hub")
  source    String   @default("contact_page")
  language  String   @default("en") // "pl" | "en"
  // Qualification lifecycle
  status    String   @default("new") // "new" | "contacted" | "qualified" | "closed_won" | "closed_lost"
  notes     String?

  ipAddress String?
  userAgent String?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([status, createdAt])
  @@index([createdAt])
}

// --- PROCUREA CONNECT: ERP/CRM INTEGRATIONS ---
//
// Three-model integration layer built on Merge.dev as the first adapter.
// IntegrationConnection = customer connected their ERP (OAuth/credentials via Merge Link)
// ExternalSupplier     = cached suppliers pulled from that ERP (synced daily)
// SupplierMatch        = dedup result linking a Procurea Supplier to an ExternalSupplier

model IntegrationConnection {
  id              String   @id @default(uuid())

  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Who set it up (for audit and support)
  connectedByUserId String?

  // Provider abstraction — "merge_dev" for MVP, future: "sap_native", "netsuite_native"
  provider        String   @default("merge_dev")

  // Identifier in the provider's system (Merge's Linked Account ID)
  providerAccountId String

  // Auth secret for this connection (Merge's X-Account-Token value).
  // Separate from providerAccountId because Merge treats them distinctly.
  // TODO: encrypt at rest via KMS before first production customer.
  providerAccountToken String?

  // What kind of system this is
  integrationCategory String   // "accounting" | "crm" | "hris"
  platformSlug        String   // Merge's slug: "netsuite" | "quickbooks-online" | "salesforce" | "dynamics-365-business-central"
  platformName        String   // Human-readable: "NetSuite", "QuickBooks Online"

  // Lifecycle
  status          String   @default("connecting") // "connecting" | "active" | "error" | "disconnected"
  statusMessage   String?  // Last error or status detail

  // Capabilities snapshot (what this specific connection can do)
  // Example: { "contacts": { "read": true, "write": true }, "purchaseOrders": { "read": true, "write": false } }
  capabilities    Json?

  // Sync state
  lastSyncedAt        DateTime?
  lastSyncSupplierCount Int     @default(0)
  nextSyncScheduledAt DateTime?

  // Relations
  externalSuppliers ExternalSupplier[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  disconnectedAt  DateTime?

  @@unique([organizationId, providerAccountId])
  @@index([organizationId, status])
  @@index([provider, platformSlug])
}

model ExternalSupplier {
  id              String   @id @default(uuid())

  connectionId    String
  connection      IntegrationConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  // Identifier of this supplier in the source ERP (as returned by Merge)
  externalId      String

  // Core identity fields — used for matching against Procurea Supplier
  name            String
  taxNumber       String?  // NIP / VAT ID / EIN — highest-confidence match signal
  website         String?  // Used for domain-based matching
  primaryEmail    String?

  // Additional data (kept structured for UI and future matching signals)
  emails          Json?    // string[]
  phoneNumbers    Json?    // string[]
  addresses       Json?    // array of { city, country, postalCode, addressLine1 }
  currency        String?

  // Merge Contact model mixes customers + vendors — we track the role
  isSupplier      Boolean  @default(true)
  isActive        Boolean  @default(true)

  // Full raw payload for future-proofing new matching signals without reschema
  rawData         Json?

  // Sync metadata
  lastSyncedAt    DateTime @default(now())
  firstSeenAt     DateTime @default(now())

  // Relations
  matches         SupplierMatch[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([connectionId, externalId])
  @@index([connectionId, isActive])
  @@index([taxNumber])
  @@index([website])
  @@index([name])
}

model SupplierMatch {
  id                 String   @id @default(uuid())

  supplierId         String
  supplier           Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  externalSupplierId String
  externalSupplier   ExternalSupplier @relation(fields: [externalSupplierId], references: [id], onDelete: Cascade)

  // Quality of match
  confidence         Float    // 0.0 – 1.0
  matchType          String   // "exact_tax" | "exact_domain" | "fuzzy_name" | "composite" | "manual"

  // Signals that drove the match (for UI explanation and debugging)
  // Example: { "taxMatch": true, "domainMatch": false, "nameSimilarity": 0.87 }
  signals            Json?

  // Lifecycle — suggestions become confirmed/rejected by user
  status             String   @default("suggested") // "suggested" | "confirmed" | "rejected"
  confirmedByUserId  String?
  confirmedAt        DateTime?
  rejectedReason     String?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([supplierId, externalSupplierId])
  @@index([supplierId, status])
  @@index([externalSupplierId, status])
  @@index([status, confidence])
}

// =====================================================================
// SPRINT 1 — Resend Inbound Email Reply Capture
// =====================================================================

// Captures inbound email replies from suppliers, classified by AI triage.
// Replies arrive via Resend Inbound webhook → email-triage.service.ts → this table.
model OfferReply {
  id              String    @id @default(uuid())
  offerId         String
  offer           Offer     @relation(fields: [offerId], references: [id], onDelete: Cascade)

  resendEmailId   String    @unique   // Resend inbound email_id from webhook payload

  fromAddress     String
  fromName        String?
  subject         String
  textBody        String?   @db.Text
  htmlBody        String?   @db.Text

  headers         Json                // parsed headers: In-Reply-To, References, Message-ID
  attachments     Json?               // Resend attachment metadata array

  // AI Triage
  category        String              // "FORWARD" | "STORE_ONLY" | "BLOCK"
  aiAnalysis      Json                // { sentiment, extractedTerms, summary, confidence, reason }

  // Forwarding tracking
  forwardedAt     DateTime?
  forwardedTo     String?             // email address we forwarded to (user's verified email)

  receivedAt      DateTime  @default(now())
  createdAt       DateTime  @default(now())

  @@index([offerId])
  @@index([category])
  @@index([receivedAt])
}

// Webhook event deduplication — mirrors StripeEventLog pattern.
// Prevents processing the same email.received event twice.
model ResendEventLog {
  id            String   @id @default(uuid())
  eventId       String   @unique            // Resend's unique event identifier
  eventType     String                       // "email.received" etc.
  payload       Json
  processedAt   DateTime @default(now())

  @@index([eventType])
}

// =====================================================================
// SPRINT 4 — Purchase Order Module
// =====================================================================

// Generated from a SIGNED Contract; optionally synced to ERP via Merge.dev.
model PurchaseOrder {
  id              String              @id @default(uuid())
  poNumber        String?             @unique    // auto-generated e.g. "PO-2026-001"

  contractId      String
  contract        Contract            @relation(fields: [contractId], references: [id])

  offerId         String
  offer           Offer               @relation(fields: [offerId], references: [id])

  organizationId  String
  organization    Organization        @relation(fields: [organizationId], references: [id])

  status          String              @default("DRAFT") // DRAFT | SUBMITTED | CONFIRMED | DELIVERED | INVOICED | CANCELLED

  totalAmount     Float?
  currency        String?
  deliveryDate    DateTime?
  notes           String?             @db.Text

  lines           PurchaseOrderLine[]

  // Merge.dev ERP sync (Sprint 4 Faza 3)
  externalId      String?                        // Merge.dev PO ID after sync
  externalSystem  String?                        // "netsuite" | "quickbooks-online" | "xero" | etc.
  syncedAt        DateTime?

  createdById     String
  createdBy       User                @relation("PurchaseOrderCreatedBy", fields: [createdById], references: [id])

  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([contractId])
  @@index([offerId])
  @@index([organizationId])
  @@index([status])
  @@index([createdById])
}

model PurchaseOrderLine {
  id                String         @id @default(uuid())
  purchaseOrderId   String
  purchaseOrder     PurchaseOrder  @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  description       String
  quantity          Float
  unit              String?
  unitPrice         Float
  totalPrice        Float
  deliveryDate      DateTime?
  notes             String?        @db.Text
  sortOrder         Int            @default(0)

  @@index([purchaseOrderId])
}
