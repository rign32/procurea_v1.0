DATABASE_URL="postgresql://procurea:procurea-dev-2026@localhost:5432/procurea?schema=public"
NODE_ENV=development
JWT_SECRET="change-me-to-random-64-char-string"

# Security
ENABLE_DEV_LOGIN=false
ADMIN_SETUP_KEY=change-me-random-key

# Redis (required for production auth: OTP codes, token blacklist, OAuth state)
# REDIS_URL=redis://localhost:6379

# Search API (SEARCH_PROVIDER: serpapi | serper)
# SerpAPI: $0.01/query (50$/5k) — docs: https://serpapi.com
# Serper.dev: $0.001/query (50$/50k) — 10x cheaper — docs: https://serper.dev
SEARCH_PROVIDER=serpapi
SERP_API_KEY=your-serpapi-key
# SERPER_API_KEY=your-serper-key

# AI - Gemini (free key from https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-key
USE_MOCK_AI=true

# GCP Project (do NOT use GCLOUD_PROJECT — reserved by Firebase)
GCP_PROJECT_ID=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# Firebase
# FIREBASE_PROJECT_ID=your-firebase-project

# Twilio (SMS verification — https://console.twilio.com)
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_VERIFY_SERVICE_SID=your-verify-service-sid
TWILIO_PHONE_NUMBER=Procurea

# Email Service (Resend)
RESEND_API_KEY=your-resend-key
FROM_EMAIL=noreply@procurea.pl
# OVERRIDE_EMAIL=dev@test.com  # Redirect all emails to this address (non-production only)

# Frontend URL (for portal links in emails)
FRONTEND_URL=https://app.procurea.pl

# Sequence Scheduler
# If set, dayOffset is treated as units of this many minutes instead of days.
# Example: 10 → dayOffset=3 means 30 minutes (for testing follow-up timing).
# Not set → dayOffset works as days (production mode).
SEQUENCE_MINUTE_MULTIPLIER=10

# Cost controls
MAX_SEARCHES_PER_CAMPAIGN=20

# JS Rendering (ScrapingBee — optional, fallback when cheerio returns < 200 chars)
# SCRAPING_API_KEY=your-scrapingbee-key
# SCRAPING_API_URL=https://app.scrapingbee.com/api/v1/

# Cloud Scheduler cron secret (protects /internal/cron/* endpoints)
# CRON_SECRET=your-random-cron-secret
