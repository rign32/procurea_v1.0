          ]
        },
        {
          "source": "/assets/**",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "public, max-age=31536000, immutable"
            }
          ]
        },
        {
          "source": "/index.html",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-cache, no-store, must-revalidate"
            }
          ]
        },
        {
          "source": "/",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-cache, no-store, must-revalidate"
            }
          ]
        },
        {
          "source": "/favicon.svg",
          "headers": [
            {
              "key": "Content-Type",
              "value": "image/svg+xml"
            },
            {
              "key": "Cache-Control",
              "value": "public, max-age=300"
            }
          ]
        }
      ]
    },
